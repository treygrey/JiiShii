# Dependencies and build output
node_modules/
dist/
src-tauri/target/

# Local/private material
archive/
src/game.before-*/
src/game/**/*.local.*
src/game/**/*.private.*

# Keep the starter package lightweight; private runtime assets belong in an
# external game package or ignored archive.
src/game/assets/audio/**
!src/game/assets/audio/
!src/game/assets/audio/.gitkeep
src/game/assets/backgrounds/**
!src/game/assets/backgrounds/
!src/game/assets/backgrounds/.gitkeep
src/game/assets/scenes/**
!src/game/assets/scenes/
!src/game/assets/scenes/.gitkeep
src/game/assets/sprites/**
!src/game/assets/sprites/
!src/game/assets/sprites/.gitkeep
!src/game/assets/sprites/_default.recipe.js

# Local dev logs
*.log
vite-vn*.log
test-results/

# Local environment and secrets
.env
.env.*
!.env.example

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Optional packaged game saves/exports
*.save
*.sav
*.bak
